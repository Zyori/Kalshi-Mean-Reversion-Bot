# Kalshi API
KALSHI_KEY_ID=your-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.pem
KALSHI_ENVIRONMENT=demo

# The Odds API (https://the-odds-api.com - free tier: 500 req/month)
ODDS_API_KEY=your-odds-api-key

# Database (SQLite with WAL mode)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Collection cadence
# Schedule sync should be cheap; live games get the tighter polling.
SCOREBOARD_LIVE_POLL_INTERVAL_S=10
SCOREBOARD_PREGAME_POLL_INTERVAL_S=300
SCOREBOARD_IDLE_POLL_INTERVAL_S=43200
ODDS_POLL_INTERVAL_S=43200
EVENTS_POLL_INTERVAL_S=15

# Server
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# Environment: "dev" or "prod". In prod, /docs is disabled and cookies are Secure-only.
ENV=prod

# Admin auth — generate both with: python scripts/hash_password.py
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
SESSION_MAX_AGE_DAYS=30
SESSION_COOKIE_NAME=lutz_session

# Email notifications (optional - disabled if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email
# SMTP_PASSWORD=your-app-password
# NOTIFY_EMAIL=your-email
